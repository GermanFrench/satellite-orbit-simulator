<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    Main simulation window layout.

    Structure
    ─────────
    ┌─────────────┬────────────────────────┬─────────────┐
    │  Left panel │   Centre canvas (600²) │ Right panel │
    │  (controls) │   orbit drawing area   │ (telemetry) │
    └─────────────┴────────────────────────┴─────────────┘
-->
<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.simulator.controller.SimulationController"
            style="-fx-background-color: #080818;">

    <!-- ═══════════════════════════════════════════════════════════════════════
         LEFT PANEL – Simulation controls
    ════════════════════════════════════════════════════════════════════════ -->
    <left>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background: #12122a; -fx-background-color: #12122a;
                           -fx-min-width: 290; -fx-max-width: 290;">
            <content>
                <VBox spacing="10"
                      style="-fx-background-color: #12122a; -fx-min-width: 290; -fx-max-width: 290;">
                    <padding>
                        <Insets top="18" right="14" bottom="18" left="24"/>
                    </padding>

            <!-- Section header -->
            <Label text="CONTROLS"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;
                          -fx-text-fill: #8899ee;"/>

            <Label text="Satellites"
                   style="-fx-text-fill: #aabbdd; -fx-font-size: 11px;"/>
            <ListView fx:id="satelliteListView" prefHeight="120"/>

            <Button text="＋ Add Satellite"
                    onAction="#handleAddSatellite"
                    maxWidth="Infinity"
                    style="-fx-background-color: #2b5fd8; -fx-text-fill: white;
                           -fx-font-size: 12px; -fx-cursor: hand;
                           -fx-background-radius: 4;"/>

            <Separator style="-fx-background-color: #334466;"/>

            <Label text="Orbit Type"
                   style="-fx-text-fill: #aabbdd; -fx-font-size: 11px;"/>
            <ComboBox fx:id="orbitTypeComboBox" maxWidth="Infinity"/>

            <Label text="Transfer Current Orbit"
                   style="-fx-text-fill: #aabbdd; -fx-font-size: 11px;"/>
            <ComboBox fx:id="transferCurrentOrbitComboBox" maxWidth="Infinity"/>

            <Label text="Transfer Target Orbit"
                   style="-fx-text-fill: #aabbdd; -fx-font-size: 11px;"/>
            <ComboBox fx:id="transferTargetOrbitComboBox" maxWidth="Infinity"/>

            <Button text="🔁  Execute Transfer"
                    fx:id="executeTransferButton"
                    onAction="#handleExecuteTransfer"
                    maxWidth="Infinity"
                    style="-fx-background-color: #c97b18; -fx-text-fill: white;
                           -fx-font-size: 12px; -fx-cursor: hand;
                           -fx-background-radius: 4;"/>

            <Button text="✖  Cancel Transfer"
                    fx:id="cancelTransferButton"
                    onAction="#handleCancelTransfer"
                    maxWidth="Infinity"
                    style="-fx-background-color: #8a1e1e; -fx-text-fill: white;
                           -fx-font-size: 12px; -fx-cursor: hand;
                           -fx-background-radius: 4;"/>

            <Separator style="-fx-background-color: #334466;"/>

            <!-- Start -->
            <Button text="▶  Start Simulation"
                    onAction="#handleStart"
                    maxWidth="Infinity"
                    style="-fx-background-color: #1e8a3c; -fx-text-fill: white;
                           -fx-font-size: 12px; -fx-cursor: hand;
                           -fx-background-radius: 4;"/>

            <!-- Pause -->
            <Button text="⏸  Pause Simulation"
                    onAction="#handlePause"
                    maxWidth="Infinity"
                    style="-fx-background-color: #8a7a1e; -fx-text-fill: white;
                           -fx-font-size: 12px; -fx-cursor: hand;
                           -fx-background-radius: 4;"/>

            <!-- Reset -->
            <Button text="↺  Reset Simulation"
                    onAction="#handleReset"
                    maxWidth="Infinity"
                    style="-fx-background-color: #8a1e1e; -fx-text-fill: white;
                           -fx-font-size: 12px; -fx-cursor: hand;
                           -fx-background-radius: 4;"/>

            <Button text="🚀  Launch Satellite"
                    fx:id="launchSatelliteButton"
                    onAction="#handleLaunchSatellite"
                    maxWidth="Infinity"
                    style="-fx-background-color: #9a3dd6; -fx-text-fill: white;
                           -fx-font-size: 12px; -fx-cursor: hand;
                           -fx-background-radius: 4;"/>

            <Button text="🛑  Cancel Launch"
                    fx:id="cancelLaunchButton"
                    onAction="#handleCancelLaunch"
                    maxWidth="Infinity"
                    style="-fx-background-color: #7a2f8f; -fx-text-fill: white;
                           -fx-font-size: 12px; -fx-cursor: hand;
                           -fx-background-radius: 4;"/>

            <Separator style="-fx-background-color: #334466;"/>

            <!-- Altitude slider -->
            <Label text="Satellite Altitude (km)"
                   style="-fx-text-fill: #aabbdd; -fx-font-size: 11px;"/>
            <Slider fx:id="altitudeSlider"/>

            <Separator style="-fx-background-color: #334466;"/>

            <!-- Initial speed slider -->
            <Label text="Initial Speed (km/s)"
                   style="-fx-text-fill: #aabbdd; -fx-font-size: 11px;"/>
            <Slider fx:id="initialSpeedSlider"/>

            <Label text="Inclination (deg)"
                   style="-fx-text-fill: #aabbdd; -fx-font-size: 11px;"/>
            <Slider fx:id="inclinationSlider"/>

            <Label text="Mass (kg)"
                   style="-fx-text-fill: #aabbdd; -fx-font-size: 11px;"/>
            <Slider fx:id="massSlider"/>

            <Separator style="-fx-background-color: #334466;"/>

            <!-- Speed slider -->
            <Label text="Simulation Speed"
                   style="-fx-text-fill: #aabbdd; -fx-font-size: 11px;"/>
            <Slider fx:id="speedSlider"/>

                </VBox>
            </content>
        </ScrollPane>
    </left>

    <!-- ═══════════════════════════════════════════════════════════════════════
         CENTRE – Orbit canvas
    ════════════════════════════════════════════════════════════════════════ -->
    <center>
        <StackPane style="-fx-background-color: #080818;">
            <!-- The SimulationController renders onto this canvas -->
            <Canvas fx:id="orbitCanvas" width="840" height="640"/>
        </StackPane>
    </center>

    <!-- ═══════════════════════════════════════════════════════════════════════
         RIGHT PANEL – Telemetry display
    ════════════════════════════════════════════════════════════════════════ -->
    <right>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background: #12122a; -fx-background-color: #12122a;
                           -fx-min-width: 290; -fx-max-width: 290;">
            <content>
                <VBox spacing="12"
                      style="-fx-background-color: #12122a; -fx-min-width: 290; -fx-max-width: 290;">
                    <padding>
                        <Insets top="18" right="14" bottom="18" left="14"/>
                    </padding>

            <!-- Section header -->
            <Label text="TELEMETRY"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;
                          -fx-text-fill: #8899ee;"/>

            <Separator style="-fx-background-color: #334466;"/>

            <Label text="📡  Satellite Status"
                   style="-fx-text-fill: #66cc88; -fx-font-weight: bold;
                          -fx-font-size: 11px;"/>

            <Label fx:id="selectedSatelliteLabel"
                   text="Satellite: none"
                   style="-fx-text-fill: #cde3ff; -fx-font-size: 12px;
                          -fx-font-family: monospace;"/>

            <Label fx:id="orbitTypeLabel"
                   text="Orbit Type: --"
                   style="-fx-text-fill: #cde3ff; -fx-font-size: 12px;
                          -fx-font-family: monospace;"/>

            <!-- Live data labels – updated every animation frame -->
            <Label fx:id="altitudeLabel"
                   text="Altitude:  — km"
                   style="-fx-text-fill: #ccd4ff; -fx-font-size: 12px;
                          -fx-font-family: monospace;"/>

            <Label fx:id="velocityLabel"
                   text="Velocity:  — km/s"
                   style="-fx-text-fill: #ccd4ff; -fx-font-size: 12px;
                          -fx-font-family: monospace;"/>

            <Label fx:id="periodLabel"
                   text="Period:    — min"
                   style="-fx-text-fill: #ccd4ff; -fx-font-size: 12px;
                          -fx-font-family: monospace;"/>

            <Label fx:id="initialSpeedLabel"
                   text="Launch v0: — km/s"
                   style="-fx-text-fill: #ccd4ff; -fx-font-size: 12px;
                          -fx-font-family: monospace;"/>

            <Label fx:id="inclinationLabel"
                   text="Inclination: — deg"
                   style="-fx-text-fill: #ccd4ff; -fx-font-size: 12px;
                          -fx-font-family: monospace;"/>

            <Label fx:id="massLabel"
                   text="Mass: — kg"
                   style="-fx-text-fill: #ccd4ff; -fx-font-size: 12px;
                          -fx-font-family: monospace;"/>

            <Label fx:id="energyLabel"
                   text="Energy:   — MJ/kg"
                   style="-fx-text-fill: #ccd4ff; -fx-font-size: 12px;
                          -fx-font-family: monospace;"/>

            <Separator style="-fx-background-color: #334466;"/>

            <Label text="🚀  Launch Telemetry"
                   style="-fx-text-fill: #66cc88; -fx-font-weight: bold;
                          -fx-font-size: 11px;"/>

            <Label fx:id="launchStatusLabel"
                   text="Launch: Idle"
                   style="-fx-text-fill: #ccd4ff; -fx-font-size: 12px;
                          -fx-font-family: monospace;"/>

            <Label fx:id="launchAltitudeLabel"
                   text="L-Altitude: 0.0 km"
                   style="-fx-text-fill: #ccd4ff; -fx-font-size: 12px;
                          -fx-font-family: monospace;"/>

            <Label fx:id="launchVelocityLabel"
                   text="L-Velocity: 0.00 km/s"
                   style="-fx-text-fill: #ccd4ff; -fx-font-size: 12px;
                          -fx-font-family: monospace;"/>

            <Label fx:id="launchThrustLabel"
                   text="L-Thrust:   0 kN"
                   style="-fx-text-fill: #ccd4ff; -fx-font-size: 12px;
                          -fx-font-family: monospace;"/>

            <Separator style="-fx-background-color: #334466;"/>

            <Label text="🛰️  Hohmann Transfer"
                   style="-fx-text-fill: #66cc88; -fx-font-weight: bold;
                          -fx-font-size: 11px;"/>

            <Label fx:id="transferInitialOrbitLabel"
                   text="Transfer from: --"
                   style="-fx-text-fill: #ccd4ff; -fx-font-size: 12px;
                          -fx-font-family: monospace;"/>

            <Label fx:id="transferTargetOrbitLabel"
                   text="Transfer to:   --"
                   style="-fx-text-fill: #ccd4ff; -fx-font-size: 12px;
                          -fx-font-family: monospace;"/>

            <Label fx:id="transferDeltaV1Label"
                   text="Delta-v1: 0.000 km/s"
                   style="-fx-text-fill: #ccd4ff; -fx-font-size: 12px;
                          -fx-font-family: monospace;"/>

            <Label fx:id="transferDeltaV2Label"
                   text="Delta-v2: 0.000 km/s"
                   style="-fx-text-fill: #ccd4ff; -fx-font-size: 12px;
                          -fx-font-family: monospace;"/>

            <Label fx:id="transferTimeLabel"
                   text="Transfer time: 0.0 min"
                   style="-fx-text-fill: #ccd4ff; -fx-font-size: 12px;
                          -fx-font-family: monospace;"/>

            <Label fx:id="transferPhaseLabel"
                   text="Transfer phase: IDLE"
                   style="-fx-text-fill: #ccd4ff; -fx-font-size: 12px;
                          -fx-font-family: monospace;"/>

            <Separator style="-fx-background-color: #334466;"/>

            <Label fx:id="actionStatusLabel"
                   text="State: Select a satellite to enable actions."
                   wrapText="true"
                   style="-fx-text-fill: #ffdd99; -fx-font-size: 11px;"/>

            <Separator style="-fx-background-color: #334466;"/>

            <Label text="⚙  Physics"
                   style="-fx-text-fill: #66cc88; -fx-font-weight: bold;
                          -fx-font-size: 11px;"/>

            <Label text="v = √(GM / r)"
                   style="-fx-text-fill: #8899bb; -fx-font-size: 11px;
                          -fx-font-family: monospace;"/>

            <Label text="T = 2π√(r³ / GM)"
                   style="-fx-text-fill: #8899bb; -fx-font-size: 11px;
                          -fx-font-family: monospace;"/>

                </VBox>
            </content>
        </ScrollPane>
    </right>

</BorderPane>
